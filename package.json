{
  "name": "kugem",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace minigame-web",
    "dev:game-service": "npm run dev --workspace game-service",
    "build": "npm run build --workspace minigame-web",
    "build:game-service": "npm run build --workspace game-service",
    "lint": "npm run lint --workspace minigame-web",
    "preview": "npm run preview --workspace minigame-web",
    "start:game-service": "npm run start --workspace game-service",
    "test:e2e": "npx @playwright/test test",
    "test:e2e:ui": "npx @playwright/test test --ui"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@supabase/supabase-js": "^2.106.2"
  }
}
