# Local development defaults for game-service
PORT=3001
NODE_ENV=development
WEB_ORIGIN=http://localhost:5173

# Supabase (required)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_RESULT_FUNCTION_URL=https://your-project-ref.supabase.co/functions/v1/submit-game-result

# Auth verification (set one)
SUPABASE_JWT_SECRET=replace-with-jwt-secret
# SUPABASE_JWKS_URL=https://your-project-ref.supabase.co/auth/v1/.well-known/jwks.json

# Signing secret shared with submit-game-result function
GAME_SERVICE_HMAC_SECRET=replace-with-random-secret
