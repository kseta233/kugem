    {
      "name": "Rooms",
      "item": [
        {
          "name": "Create Room (Public)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('status is 201', function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "const body = pm.response.json();",
                  "if (body && body.room) {",
                  "  pm.collectionVariables.set('roomId', body.room.roomId);",
                  "  pm.collectionVariables.set('roomCode', body.room.roomCode);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "x-user-id",
                "value": "{{userA}}"
              },
              {
                "key": "x-app-secret",
                "value": "{{appSecret}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"gameType\": \"{{gameType}}\",\n  \"displayName\": \"Player A\",\n  \"maxPlayers\": 2\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/v1/rooms",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "v1",
                "rooms"
              ]
            }
          },
          "response": []
        },
