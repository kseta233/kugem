{
  "name": "game-service",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=22",
    "npm": ">=10"
  },
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/main.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "tsx --test src/integration/*.test.ts src/modules/*/*.test.ts"
  },
  "dependencies": {
    "@fastify/cors": "^11.1.0",
    "@supabase/supabase-js": "^2.57.4",
    "dotenv": "^17.2.3",
    "fastify": "^5.6.1"
  },
  "devDependencies": {
    "@types/node": "^24.12.3",
    "tsx": "^4.20.6",
    "typescript": "6.0.3"
  }
}
